rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validate Contact Message
    function isValidContactMessage(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'email', 'subject', 'message', 'to', 'createdAt', 'status'])
        && data.keys().size() == 8
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.email is string && data.email.size() <= 200 && data.email.matches('.*@.*')
        && data.subject is string && data.subject.size() <= 200
        && data.message is string && data.message.size() <= 5000
        && data.to == 'info@zamlux.de'
        && data.createdAt == request.time
        && data.status == 'new';
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customer', 'items', 'total', 'paymentMethod', 'status', 'createdAt'])
        && data.keys().size() >= 6
        && data.customer.vorname is string && data.customer.vorname.size() <= 100
        && data.customer.nachname is string && data.customer.nachname.size() <= 100
        && data.customer.email is string && data.customer.email.size() <= 200 && data.customer.email.matches('.*@.*')
        && data.customer.strasse is string && data.customer.strasse.size() <= 200
        && data.customer.plz is string && data.customer.plz.size() <= 10
        && data.customer.stadt is string && data.customer.stadt.size() <= 100
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number && data.total > 0
        && data.paymentMethod is string
        && data.status in ['pending', 'paid', 'shipped', 'cancelled']
        && data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'email', 'createdAt'])
        && data.keys().size() >= 4
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.email is string && data.email.size() <= 200 && data.email.matches('.*@.*')
        && (data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt));
    }

    // Contacts collection
    match /contacts/{messageId} {
      allow create: if isValidContactMessage(request.resource.data);
      allow read: if isSignedIn();
    }

    // Users collection
    match /users/{userId} {
      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    // Orders collection
    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read: if isSignedIn();
      allow update: if true;
    }

    // Inventory collection
    match /inventory/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Stock History collection
    match /stock_history/{historyId} {
      allow read: if true;
      allow write: if true;
    }

    // Mail collection (for Trigger Email extension)
    match /mail/{mailId} {
      // allow create for anyone so the form can trigger emails
      allow create: if isSignedIn() || true; // In a production app, you might restrict this more
      
      // Prevent users from reading or deleting mail documents (only the extension should process them)
      allow read, update, delete: if false; 
    }
  }
}
